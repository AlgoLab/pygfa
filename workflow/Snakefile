# -*- mode: snakemake; -*-
# Snakemake workflow for single-parameter BGFA benchmarking
# For each option, test all encoding values while keeping others at identity
#
# Usage:
#   snakemake -s workflow/Snakefile --configfile workflow/config.yaml -j 8
#   snakemake -s workflow/Snakefile --configfile workflow/config.yaml -n  # dry run

import os
import sys
import subprocess
import json

sys.path.insert(0, "test")
from benchmark_filter import filter_gfa_files, extract_header_comments


def discover_encodings():
    """Discover available encodings from bgfatools show-full-encodings"""
    cmd = ["pixi", "run", "python", "bin/bgfatools", "show-full-encodings"]
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        raise Exception(f"Failed to discover encodings: {result.stderr}")
    raw_encodings = json.loads(result.stdout)
    
    encoding_map = {
        "two_bit_dna": "2bit",
        "elias_gamma": "gamma",
        "elias_omega": "omega",
        "simple_8b": "simple8b",
        "identity": "none",
    }
    
    encodings = {}
    for option, methods in raw_encodings.items():
        normalized = []
        seen = set()
        for m in methods:
            if m == "bwt_huffman":
                continue
            mapped = encoding_map.get(m, m)
            if mapped and mapped not in seen:
                normalized.append(mapped)
                seen.add(mapped)
        encodings[option] = normalized
    
    return encodings


def discover_datasets():
    """Discover GFA files with # benchmark: comment"""
    all_files = filter_gfa_files("data", None)
    datasets = {}

    for file_path in all_files:
        comments = extract_header_comments(file_path)
        has_benchmark = any(c.startswith("# benchmark:") for c in comments)
        if not has_benchmark:
            continue

        filename = os.path.basename(file_path)
        if filename.endswith(".gfa.gz"):
            dataset_name = filename[:-7]
        elif filename.endswith(".gfa"):
            dataset_name = filename[:-4]
        else:
            dataset_name = filename

        if dataset_name in datasets:
            parent_dir = os.path.basename(os.path.dirname(file_path))
            dataset_name = f"{parent_dir}_{dataset_name}"

        datasets[dataset_name] = file_path

    return datasets


BLOCK_SIZES = config.get("block_sizes", [
    512, 1024, 2048, 4096, 8192, 16384, 32768,
    65536, 131072, 262144
])

OUTPUT_DIR = config.get("output_dir", "results/benchmark")

_CACHED_ENCODINGS = None
_CACHED_DATASETS = None


def get_cached_data():
    global _CACHED_ENCODINGS, _CACHED_DATASETS
    if _CACHED_ENCODINGS is None:
        _CACHED_ENCODINGS = discover_encodings()
        _CACHED_DATASETS = discover_datasets()
    return _CACHED_ENCODINGS, _CACHED_DATASETS


def get_all_csv_files():
    encodings, datasets = get_cached_data()
    options = list(encodings.keys())
    files = []
    for option in options:
        for encoding in encodings[option]:
            for block_size in BLOCK_SIZES:
                for dataset in datasets:
                    files.append(f"{OUTPUT_DIR}/{option}/{dataset}/{encoding}_{block_size}.csv")
    return files


rule all:
    input:
        OUTPUT_DIR + "/summary.csv.zstd"


rule aggregate_results:
    input:
        get_all_csv_files()
    output:
        OUTPUT_DIR + "/summary.csv.zstd"
    shell:
        "(head -n 1 {input[0]} && tail -n +2 -q {input}) | zstd > {output}"


rule generate_bgfa:
    input:
        gfa=lambda wildcards: get_cached_data()[1][wildcards.dataset]
    output:
        bgfa=OUTPUT_DIR + "/{option}/{dataset}/{encoding}_{block_size}.bgfa"
    params:
        block_size=lambda wildcards: wildcards.block_size
    run:
        option = wildcards.option
        encoding = wildcards.encoding

        bgfa_cmd = [
            "pixi", "run", "python", "bin/bgfatools", "bgfa",
            input.gfa,
            output.bgfa,
            "--block-size", str(params.block_size),
        ]

        # Mapping from encoding option names to CLI argument suffixes
        ENCODING_CLI_MAP = {
            "segment_names_header": "segment-names",
            "segment_names_payload_lengths": "segment-names-lens",
            "segment_names_payload_names": "segment-names-names",
            "segments_header": "segments",
            "segments_payload_lengths": "segments-lens",
            "segments_payload_strings": "segments-seq",
            "links_header": "links",
            "links_payload_from": "links-from",
            "links_payload_to": "links-to",
            "links_payload_cigar_lengths": "links-cigar-lens",
            "links_payload_cigar": "links-cigar",
            "paths_header": "paths",
            "paths_payload_names": "paths-names",
            "paths_payload_segment_lengths": "paths-seg-lens",
            "paths_payload_path_ids": "paths-ids",
            "paths_payload_cigar_lengths": "paths-cigar-lens",
            "paths_payload_cigar": "paths-cigar",
            "walks_header": "walks",
            "walks_payload_sample_ids": "walks-samples",
            "walks_payload_hep_indices": "walks-heps",
            "walks_payload_sequence_ids": "walks-seqs",
            "walks_payload_start": "walks-start",
            "walks_payload_end": "walks-end",
            "walks_payload_walks": "walks-data",
        }
        
        all_options = get_cached_data()[0].keys()
        for opt in all_options:
            cli_suffix = ENCODING_CLI_MAP[opt]
            cli_opt = f"--compress-{cli_suffix}"
            if opt == option:
                bgfa_cmd.extend([cli_opt, encoding])
            else:
                bgfa_cmd.extend([cli_opt, "none"])

        result = subprocess.run(bgfa_cmd, capture_output=True, text=True)
        if result.returncode != 0:
            print(f"ERROR: Encoding failed for {input.gfa}", file=sys.stderr)
            print(f"Command: {' '.join(bgfa_cmd)}", file=sys.stderr)
            print(f"stdout: {result.stdout}", file=sys.stderr)
            print(f"stderr: {result.stderr}", file=sys.stderr)
            raise Exception(f"bgfatools bgfa failed: {result.stderr}")


rule measure_bgfa:
    input:
        bgfa=OUTPUT_DIR + "/{option}/{dataset}/{encoding}_{block_size}.bgfa",
        gfa=lambda wildcards: get_cached_data()[1][wildcards.dataset]
    output:
        csv=OUTPUT_DIR + "/{option}/{dataset}/{encoding}_{block_size}.csv"
    run:
        import tempfile, os
        fd, temp_csv = tempfile.mkstemp(suffix=".csv", dir=OUTPUT_DIR, prefix="measure_")
        os.close(fd)

        measure_cmd = [
            "pixi", "run", "python", "bin/bgfatools", "measure",
            input.bgfa,
            temp_csv,
        ]

        measure_result = subprocess.run(measure_cmd, capture_output=True, text=True)
        if measure_result.returncode != 0:
            print(f"ERROR: Measurement failed for {input.bgfa}", file=sys.stderr)
            print(f"Command: {' '.join(measure_cmd)}", file=sys.stderr)
            print(f"stdout: {measure_result.stdout}", file=sys.stderr)
            print(f"stderr: {measure_result.stderr}", file=sys.stderr)
            raise Exception(f"bgfatools measure failed: {measure_result.stderr}")

        gfa_path = input.gfa
        with open(temp_csv, "r") as f_in:
            with open(output.csv, "w") as f_out:
                for line in f_in:
                    if line.startswith("filename,"):
                        f_out.write("original_gfa," + line)
                    else:
                        f_out.write(gfa_path + "," + line)

        os.remove(temp_csv)
