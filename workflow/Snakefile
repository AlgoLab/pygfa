# -*- mode: snakemake; -*-
# Snakemake workflow for single-parameter BGFA benchmarking
# For each option, test all encoding values while keeping others at identity
#
# Usage:
#   snakemake -s workflow/Snakefile --configfile workflow/config.yaml -j 8
#   snakemake -s workflow/Snakefile --configfile workflow/config.yaml -n  # dry run

import os
import sys
import subprocess
import json
import re

sys.path.insert(0, "test")
from benchmark_filter import filter_gfa_files, extract_header_comments


def discover_encodings():
    """Discover available encodings from bgfatools show-full-encodings.

    For multi-byte fields (composite values with '+' separator), splits into
    per-byte option entries. E.g. compression_segment_names becomes:
      - compression_segment_names_1: byte 1 values, byte 2 fixed to identity
      - compression_segment_names_2: byte 2 values, byte 1 fixed to identity

    Single-byte fields remain unchanged.
    """
    # Encodings to exclude from benchmarks
    EXCLUDED_ENCODINGS = {"bwt_huffman"}

    cmd = ["pixi", "run", "python", "bin/bgfatools", "show-full-encodings"]
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        raise Exception(f"Failed to discover encodings: {result.stderr}")
    raw_encodings = json.loads(result.stdout)

    encoding_map = {
        "two_bit_dna": "2bit",
        "elias_gamma": "gamma",
        "elias_omega": "omega",
        "simple_8b": "simple8b",
        "identity": "none",
    }

    def _normalize(name):
        return encoding_map.get(name, name)

    encodings = {}
    for option, methods in raw_encodings.items():
        if not methods:
            continue

        is_multi_byte = '+' in methods[0]

        if is_multi_byte:
            num_bytes = len(methods[0].split('+'))
            per_byte = [[] for _ in range(num_bytes)]
            seen_per_byte = [set() for _ in range(num_bytes)]

            for m in methods:
                parts = m.split('+')
                for i, part in enumerate(parts):
                    mapped = _normalize(part)
                    if mapped and mapped not in seen_per_byte[i] and mapped not in EXCLUDED_ENCODINGS:
                        per_byte[i].append(mapped)
                        seen_per_byte[i].add(mapped)

            for byte_idx in range(num_bytes):
                encodings[f"{option}_{byte_idx + 1}"] = sorted(per_byte[byte_idx])
        else:
            normalized = []
            seen = set()
            for m in methods:
                mapped = _normalize(m)
                if mapped and mapped not in seen and mapped not in EXCLUDED_ENCODINGS:
                    normalized.append(mapped)
                    seen.add(mapped)
            encodings[option] = sorted(normalized)

    return encodings


def discover_datasets():
    """Discover GFA files with # benchmark: comment"""
    all_files = filter_gfa_files(".", None)
    datasets = {}

    for file_path in all_files:
        comments = extract_header_comments(file_path)
        has_benchmark = any(re.match(r"^#\s*benchmark:", c) for c in comments)
        if not has_benchmark:
            continue

        filename = os.path.basename(file_path)
        if filename.endswith(".gfa.gz"):
            dataset_name = filename[:-7]
        elif filename.endswith(".gfa"):
            dataset_name = filename[:-4]
        else:
            dataset_name = filename

        if dataset_name in datasets:
            parent_dir = os.path.basename(os.path.dirname(file_path))
            dataset_name = f"{parent_dir}_{dataset_name}"

        datasets[dataset_name] = os.path.relpath(file_path, ".")

    return datasets


BLOCK_SIZES = config.get("block_sizes", [
    512, 1024, 2048, 4096, 8192, 16384, 32768,
    65536, 131072, 262144
])

OUTPUT_DIR = config.get("output_dir", "results/benchmark")

MEMORY_LIMIT_MB = config.get("memory_limit_mb", 4096)

_CACHED_ENCODINGS = None
_CACHED_DATASETS = None


def get_cached_data():
    global _CACHED_ENCODINGS, _CACHED_DATASETS
    if _CACHED_ENCODINGS is None:
        _CACHED_ENCODINGS = discover_encodings()
        _CACHED_DATASETS = discover_datasets()
    return _CACHED_ENCODINGS, _CACHED_DATASETS


def get_all_csv_files():
    encodings, datasets = get_cached_data()
    options = list(encodings.keys())
    files = []
    for option in options:
        for encoding in encodings[option]:
            for block_size in BLOCK_SIZES:
                for dataset in datasets:
                    files.append(f"{OUTPUT_DIR}/{option}/{dataset}/{encoding}_{block_size}.csv")
    return files


# Mapping from base compression option names to bgfatools CLI flag names.
# Used by _build_compress_flags to determine which CLI flag each option controls.
OPTION_CLI_MAP = {
    "compression_segment_names": "--names-enc",
    "compression_sequences": "--seq-enc",
    "compression_from": "--links-fromto-enc",
    "compression_to": "--links-fromto-enc",
    "compression_cigars": "--links-cigars-enc",
    "compression_path_names": "--paths-names-enc",
    "compression_paths": "--paths-paths-enc",
    "compression_sample_ids": "--walks-sample-ids-enc",
    "compression_haplotype_indices": "--walks-hap-indices-enc",
    "compression_sequence_ids": "--walks-seq-ids-enc",
    "compression_positions_start": "--walks-start-enc",
    "compression_positions_end": "--walks-end-enc",
    "compression_walks": "--walks-walks-enc",
}


def _build_compress_flags(option, encoding):
    """Build shell string of compression flags for bgfatools CLI.

    For byte-position options (e.g. compression_segment_names_2), builds
    a composite encoding with all other bytes set to identity (none).
    """
    # Detect byte position suffix: option names like "compression_xxx_N"
    base_option = option
    byte_position = None
    m = re.match(r'^(.+)_([0-9]+)$', option)
    if m and m.group(1) in OPTION_CLI_MAP:
        base_option = m.group(1)
        byte_position = int(m.group(2))

    encodings, _ = get_cached_data()

    cli_to_options = {}
    for opt, cli_flag in OPTION_CLI_MAP.items():
        cli_to_options.setdefault(cli_flag, []).append(opt)

    flags = []
    for cli_flag, opts in cli_to_options.items():
        if base_option in opts:
            if byte_position is not None:
                # Determine total bytes from existing per-byte keys
                num_bytes = 1
                for key in encodings:
                    km = re.match(rf'^{re.escape(base_option)}_([0-9]+)$', key)
                    if km:
                        num_bytes = max(num_bytes, int(km.group(1)))

                parts = ["none"] * num_bytes
                parts[byte_position - 1] = encoding
                val = "-".join(parts)
            else:
                val = encoding
        else:
            val = "none"
        flags.append(f"{cli_flag} {val}")
    return " ".join(flags)


rule all:
    input:
        OUTPUT_DIR + "/summary.csv.zst"


rule compress_summary:
    input:
        OUTPUT_DIR + "/summary.csv"
    output:
        OUTPUT_DIR + "/summary.csv.zst"
    shell:
        "zstd -f {input} -o {output}"


rule generate_summary:
    input:
        get_all_csv_files()
    output:
        OUTPUT_DIR + "/summary.csv"
    shell:
        "head -n 1 {input[0]} > {output} && "
        "for f in {input}; do tail -n +2 -q \"$f\" >> {output}; done"


rule generate_bgfa:
    input:
        gfa=lambda wildcards: get_cached_data()[1][wildcards.dataset]
    output:
        bgfa=OUTPUT_DIR + "/{option}/{dataset}/{encoding}_{block_size}.bgfa"
    params:
        compress_flags=lambda wildcards: _build_compress_flags(wildcards.option, wildcards.encoding),
    resources:
        mem_mb=MEMORY_LIMIT_MB,
    shell:
        "pixi run python bin/bgfatools bgfa {input.gfa} {output.bgfa} "
        "--block-size {wildcards.block_size} {params.compress_flags} "
        "2>&1 && rm -f {output.bgfa}.log || "
        "{{ echo 'ERROR: Encoding failed for {input.gfa}' >&2; exit 1; }}"


rule measure_bgfa:
    input:
        bgfa=OUTPUT_DIR + "/{option}/{dataset}/{encoding}_{block_size}.bgfa",
        gfa=lambda wildcards: get_cached_data()[1][wildcards.dataset]
    output:
        csv=OUTPUT_DIR + "/{option}/{dataset}/{encoding}_{block_size}.csv"
    params:
        option="{option}",
        encoding="{encoding}",
    resources:
        mem_mb=MEMORY_LIMIT_MB,
    shell:
        "tmp=$(mktemp -p {OUTPUT_DIR} measure_XXXXXX.csv) && "
        "pixi run python bin/bgfatools measure {input.bgfa} \"$tmp\" && "
        "awk -v gfa=\"{input.gfa}\" -v opt=\"{params.option}\" -v enc=\"{params.encoding}\" 'NR==1{{print \"original_gfa,option,value,\" $0}} NR>1{{print gfa \",\" opt \",\" enc \",\" $0}}' \"$tmp\" > {output.csv} && "
        "rm -f \"$tmp\" {input.bgfa}.log || "
        "{{ echo 'ERROR: Measurement failed for {input.bgfa}' >&2; exit 1; }}"