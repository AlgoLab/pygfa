def enc_to_flag(enc):
    return "" if enc == "identity" else enc

def get_int_encoding_csvs():
    files = []
    for dataset in INT_DATASETS:
        for enc in INT_ENCODINGS:
            files.append(f"{OUTPUT_DIR}/int_encoding/{dataset}/{enc}.csv")
    return files

def get_str_encoding_csvs():
    files = []
    for dataset in STR_DATASETS:
        for enc in STR_ENCODINGS:
            files.append(f"{OUTPUT_DIR}/str_encoding/{dataset}/{enc}.csv")
    return files

def get_block_size_csvs():
    files = []
    for dataset in BLOCK_SIZE_DATASETS:
        for size in BLOCK_SIZES:
            files.append(f"{OUTPUT_DIR}/block_size/{dataset}/{size}.csv")
    return files

def get_block_specific_csvs():
    files = []
    for dataset in BLOCK_SPECIFIC_DATASETS:
        for block_type, cfg in BLOCK_SPECIFIC_CONFIG.items():
            for int_enc in cfg["int_encodings"]:
                for str_enc in cfg["str_encodings"]:
                    files.append(f"{OUTPUT_DIR}/block_specific/{dataset}/{block_type}_{int_enc}_{str_enc}.csv")
    return files

def get_section_csvs():
    files = []
    for section, cfg in SECTION_SPECIFIC_CONFIG.items():
        datasets = SECTION_DATASETS.get(section, {})
        enc_type = cfg.get("type", "string")
        encodings = cfg.get("encodings", [])
        for dataset_name in datasets:
            for enc in encodings:
                files.append(f"{OUTPUT_DIR}/section/{section}/{dataset_name}/{enc}.csv")
    return files

def get_all_csv_files():
    return (get_int_encoding_csvs() + get_str_encoding_csvs() + 
            get_block_size_csvs() + get_block_specific_csvs() + 
            get_section_csvs())

rule all:
    input:
        OUTPUT_DIR + "/summary-single-parameter.csv.zstd"

rule benchmark_int_encoding_only:
    input:
        get_int_encoding_csvs()

rule benchmark_str_encoding_only:
    input:
        get_str_encoding_csvs()

rule benchmark_block_size_only:
    input:
        get_block_size_csvs()

rule benchmark_block_specific_only:
    input:
        get_block_specific_csvs()

rule aggregate_single_param_results:
    input:
        get_all_csv_files()
    output:
        OUTPUT_DIR + "/summary-single-parameter.csv.zstd"
    shell:
        "(head -n 1 {input[0]} && tail -n +2 -q {input}) | zstd > {output}"

rule benchmark_int_encoding:
    input:
        gfa=lambda wildcards: INT_DATASETS[wildcards.dataset]
    output:
        csv=OUTPUT_DIR + "/int_encoding/{dataset}/{int_enc}.csv"
    params:
        bgfa=OUTPUT_DIR + "/int_encoding/{dataset}/{int_enc}.bgfa",
        int_flag=lambda wildcards: enc_to_flag(wildcards.int_enc)
    shell:
        """
        pixi run python workflow/scripts/benchmark_encode.py \
            --input-gfa "{input.gfa}" \
            --output-bgfa "{params.bgfa}" \
            --output-csv "{output.csv}" \
            --int-flag "{params.int_flag}" \
            --str-flag ""
        """

