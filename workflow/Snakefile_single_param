            --str-flag "{params.str_flag}"
        """

rule benchmark_section:
    input:
        gfa=lambda wildcards: SECTION_DATASETS[wildcards.section][wildcards.dataset]
    output:
        csv=OUTPUT_DIR + "/section/{section}/{dataset}/{encoding}.csv"
    params:
        bgfa=OUTPUT_DIR + "/section/{section}/{dataset}/{encoding}.bgfa",
        section=lambda wildcards: wildcards.section,
        encoding=lambda wildcards: wildcards.encoding
    run:
        cfg = SECTION_SPECIFIC_CONFIG.get(wildcards.section, {})
        enc_type = cfg.get("type", "string")
        int_flag = enc_to_flag(wildcards.encoding) if enc_type == "integer" else ""
        str_flag = enc_to_flag(wildcards.encoding) if enc_type == "string" else ""
        shell(
            "pixi run python workflow/scripts/benchmark_encode_single_param.py "
            "--input-gfa '{input.gfa}' "
            "--output-bgfa '{params.bgfa}' "
            "--output-csv '{output.csv}' "
            "--section '{params.section}' "
            "--int-flag '{int_flag}' "
            "--str-flag '{str_flag}'"
        )
