#!/usr/bin/env python3
"""
bgfatools - Command line tool for working with BGFA files
"""

import sys
import argparse
import os
import tomllib
import logging
import tempfile
import json
from pygfa.gfa import GFA
from pygfa.encoding import (
    show_full_encodings,
    INTEGER_ENCODINGS,
    STRING_ENCODINGS,
)
from pygfa.bgfa import measure_bgfa


def get_group_args(parser, group_name, parsed_args):
    """Extracts only the arguments belonging to a specific group."""
    arg_group = None
    for g in parser._action_groups:
        if g.title == group_name:
            arg_group = g
            break
    if arg_group is None:
        return {}

    group_dict = {}
    for action in arg_group._group_actions:
        # Skip actions that don't have a dest attribute
        if hasattr(action, "dest") and action.dest:
            if hasattr(parsed_args, action.dest):
                group_dict[action.dest] = getattr(parsed_args, action.dest)
    return group_dict


def parse_cli_options():
    """Parse the command line, returns an options, positional_arguments, compression_options dicts"""
    options = {}
    parser = argparse.ArgumentParser(
        description="Tool for converting between GFA and BGFA formats", prog="bgfatools"
    )
    subparsers = parser.add_subparsers(dest="command", help="Subcommands")

    # bgfa subcommand
    bgfa_parser = subparsers.add_parser("bgfa", help="Convert GFA to BGFA format")
    bgfa_parser.add_argument("input_file", help="Path to input GFA file")
    bgfa_parser.add_argument("output_file", help="Path to output BGFA file")
    bgfa_parser.add_argument(
        "--block-size",
        type=int,
        default=1024,
        help="Block size for BGFA format (default: 1024)",
    )
    bgfa_parser.add_argument(
        "--verbose", "-v", action="store_true", help="Enable verbose output"
    )
    bgfa_parser.add_argument(
        "--config", "-c", type=str, help="Path to TOML configuration file"
    )

    # Strategy options for every component
    strategy_group = bgfa_parser.add_argument_group("Strategy Options (Format: int-str, e.g. varint-huffman)")
    strategy_group.add_argument("--names-enc", type=str, default="varint-none")
    strategy_group.add_argument("--seq-enc", type=str, default="varint-none")
    strategy_group.add_argument("--links-fromto-enc", type=str, default="varint-none")
    strategy_group.add_argument("--links-cigars-enc", type=str, default="varint-none")
    strategy_group.add_argument("--paths-names-enc", type=str, default="varint-none")
    strategy_group.add_argument("--paths-paths-enc", type=str, default="varint-none")
    strategy_group.add_argument("--paths-cigars-enc", type=str, default="varint-none")
    strategy_group.add_argument("--walks-sample-ids-enc", type=str, default="varint-none")
    strategy_group.add_argument("--walks-hap-indices-enc", type=str, default="varint-none")
    strategy_group.add_argument("--walks-seq-ids-enc", type=str, default="varint-none")
    strategy_group.add_argument("--walks-start-enc", type=str, default="varint-none")
    strategy_group.add_argument("--walks-end-enc", type=str, default="varint-none")
    strategy_group.add_argument("--walks-walks-enc", type=str, default="varint-none")

    # cat subcommand

    # cat subcommand
    cat_parser = subparsers.add_parser(
        "cat", help="Convert BGFA to GFA format and output to stdout"
    )
    cat_parser.add_argument("input_file", help="Path to input BGFA file")
    cat_parser.add_argument(
        "--output", "-o", type=str, help="Output file (default: stdout)"
    )

    # measure subcommand
    measure_parser = subparsers.add_parser(
        "measure", help="Analyze BGFA file structure and output block statistics to CSV"
    )
    measure_parser.add_argument("input_file", help="Path to input BGFA file")
    measure_parser.add_argument("output_file", help="Path to output CSV file")

    # show-full-encodings subcommand
    subparsers.add_parser(
        "show-full-encodings", help="Show all compression encoding options as JSON"
    )

    # Options common to all commands
    parser.add_argument(
        "--verbose",
        "-v",
        action="store_true",
        help="Enable verbose output (INFO level)",
    )
    parser.add_argument(
        "--debug",
        "-d",
        action="store_true",
        help="Enable debug output (more detailed than verbose)",
    )
    parser.add_argument(
        "--logfile",
        "-l",
        type=str,
        help="Path to log file (if not specified and verbose/debug=True, uses a temporary file)",
    )
    parser.add_argument(
        "--config", "-c", type=str, help="Path to TOML configuration file"
    )
    # Add all options to the help output
    parser.add_argument(
        "--help-all", action="store_true", help="Show all options in help output"
    )

    # Parse arguments
    try:
        args = parser.parse_args()
    except SystemExit:
        # argparse will call sys.exit() on error, so we catch it
        sys.exit(1)

    # The actual group titles in argparse might be different
    # Let's manually extract what we need
    options = {}
    compression_options = {}

    # Extract known options
    if hasattr(args, "command"):
        options["command"] = args.command
    if hasattr(args, "block_size"):
        options["block_size"] = args.block_size
    if hasattr(args, "verbose"):
        options["verbose"] = args.verbose
    if hasattr(args, "debug"):
        options["debug"] = args.debug
    if hasattr(args, "logfile"):
        options["logfile"] = args.logfile
    if hasattr(args, "config"):
        options["config"] = args.config
    if hasattr(args, "output"):
        options["output"] = args.output
    if hasattr(args, "original_gfa"):
        options["original_gfa"] = args.original_gfa

    # Extract positional arguments and save them to the options dict
    if hasattr(args, "input_file"):
        options["input_file"] = args.input_file
    if hasattr(args, "output_file"):
        options["output_file"] = args.output_file

    # Extract strategy options for bgfa command
    if hasattr(args, "names_enc"):
        options["names_enc"] = args.names_enc
    if hasattr(args, "seq_enc"):
        options["seq_enc"] = args.seq_enc
    if hasattr(args, "links_fromto_enc"):
        options["links_fromto_enc"] = args.links_fromto_enc
    if hasattr(args, "links_cigars_enc"):
        options["links_cigars_enc"] = args.links_cigars_enc
    if hasattr(args, "paths_names_enc"):
        options["paths_names_enc"] = args.paths_names_enc
    if hasattr(args, "paths_paths_enc"):
        options["paths_paths_enc"] = args.paths_paths_enc
    if hasattr(args, "paths_cigars_enc"):
        options["paths_cigars_enc"] = args.paths_cigars_enc
    if hasattr(args, "walks_sample_ids_enc"):
        options["walks_sample_ids_enc"] = args.walks_sample_ids_enc
    if hasattr(args, "walks_hap_indices_enc"):
        options["walks_hap_indices_enc"] = args.walks_hap_indices_enc
    if hasattr(args, "walks_seq_ids_enc"):
        options["walks_seq_ids_enc"] = args.walks_seq_ids_enc
    if hasattr(args, "walks_start_enc"):
        options["walks_start_enc"] = args.walks_start_enc
    if hasattr(args, "walks_end_enc"):
        options["walks_end_enc"] = args.walks_end_enc
    if hasattr(args, "walks_walks_enc"):
        options["walks_walks_enc"] = args.walks_walks_enc

    # Extract compression options (they have specific names)
    comp_prefixes = [
        "compress-segment-names",
        "compress-segment-names-lens",
        "compress-segment-names-names",
        "compress-segments",
        "compress-segments-lens",
        "compress-segments-seq",
        "compress-links",
        "compress-links-from",
        "compress-links-to",
        "compress-links-cigar-lens",
        "compress-links-cigar",
        "compress-paths",
        "compress-paths-names",
        "compress-paths-seg-lens",
        "compress-paths-ids",
        "compress-paths-cigar-lens",
        "compress-paths-cigar",
        "compress-walks",
        "compress-walks-samples",
        "compress-walks-heps",
        "compress-walks-seqs",
        "compress-walks-start",
        "compress-walks-end",
        "compress-walks-data",
    ]

    for prefix in comp_prefixes:
        attr_name = prefix.replace("-", "_")
        if hasattr(args, attr_name):
            compression_options[prefix] = getattr(args, attr_name)

    # Load configuration from TOML file if provided
    config = {}
    if args.config:
        if not os.path.exists(args.config):
            print(
                f"Error: Configuration file '{args.config}' not found", file=sys.stderr
            )
            sys.exit(1)

        try:
            with open(args.config, "rb") as f:
                config = tomllib.load(f)
        except ValueError as e:
            print(
                f"Error: Invalid TOML format in '{args.config}': {e}", file=sys.stderr
            )
            sys.exit(1)
        except Exception as e:
            print(
                f"Error: Failed to read configuration file '{args.config}': {e}",
                file=sys.stderr,
            )
            sys.exit(1)

    # Merge command line arguments with configuration file values
    for opt in compression_options.keys():
        if opt in config:
            compression_options[opt] = config[opt]
    for opt in options.keys():
        if opt in config:
            options[opt] = config[opt]
    # Validate compression methods
    for component, method in compression_options.items():
        if method and method not in INTEGER_ENCODINGS and method not in STRING_ENCODINGS:
            print(
                f"Error: Invalid compression method '{method}' for {component}. "
                f"Valid methods are: {list(INTEGER_ENCODINGS.keys()) + list(STRING_ENCODINGS.keys())}",
                file=sys.stderr,
            )
            sys.exit(1)

    return options, compression_options


if __name__ == "__main__":
    import sys

    options, compression_options = parse_cli_options()

    # Check if we got the required data
    if not options:
        print("Error: Failed to parse command line options.", file=sys.stderr)
        sys.exit(1)

    # Determine log level
    if options.get("debug"):
        log_level = logging.DEBUG
    elif options.get("verbose"):
        log_level = logging.INFO
    else:
        log_level = logging.WARNING

    # If logfile is not provided, create a temporary one
    logfile = options.get("logfile")
    if logfile is None:
        temp_log = tempfile.NamedTemporaryFile(mode="w", delete=False, suffix=".log")
        logfile = temp_log.name
        temp_log.close()
        print(f"Logging to temporary file: {logfile}", file=sys.stderr)

    # Clear any existing handlers
    logging.getLogger().handlers.clear()

    # Create formatter
    formatter = logging.Formatter(
        "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
    )

    # Create file handler
    file_handler = logging.FileHandler(logfile)
    file_handler.setLevel(log_level)
    file_handler.setFormatter(formatter)

    # Create stream handler (console)
    stream_handler = logging.StreamHandler()
    stream_handler.setLevel(log_level)
    stream_handler.setFormatter(formatter)

    # Configure root logger
    logging.basicConfig(level=log_level, handlers=[file_handler, stream_handler])

    logger = logging.getLogger(__name__)
    logger.info("Starting bgfatools command: %s", options.get("command"))

    if options.get("command") == "bgfa":
        try:
            # Read GFA file
            logger.info("Reading GFA file from %s", options.get("input_file"))
            g = GFA.from_gfa(options.get("input_file"))

            # Write BGFA file
            logger.info("Writing BGFA file to %s", options.get("output_file"))
            verbose_mode = options.get("verbose", False) or options.get("debug", False)
            g.to_bgfa(
                options.get("output_file"),
                block_size=options.get("block_size", 1024),
                verbose=verbose_mode,
                debug=options.get("debug", False),
                logfile=options.get("logfile"),
                # New granular strategy options
                names_enc=options.get("names_enc", "varint-none"),
                seq_enc=options.get("seq_enc", "varint-none"),
                links_fromto_enc=options.get("links_fromto_enc", "varint-none"),
                links_cigars_enc=options.get("links_cigars_enc", "varint-none"),
                paths_names_enc=options.get("paths_names_enc", "varint-none"),
                paths_paths_enc=options.get("paths_paths_enc", "varint-none"),
                paths_cigars_enc=options.get("paths_cigars_enc", "varint-none"),
                walks_sample_ids_enc=options.get("walks_sample_ids_enc", "varint-none"),
                walks_hap_indices_enc=options.get("walks_hap_indices_enc", "varint-none"),
                walks_seq_ids_enc=options.get("walks_seq_ids_enc", "varint-none"),
                walks_start_enc=options.get("walks_start_enc", "varint-none"),
                walks_end_enc=options.get("walks_end_enc", "varint-none"),
                walks_walks_enc=options.get("walks_walks_enc", "varint-none"),
            )

            if options.get("verbose"):
                print(
                    f"Successfully converted {options.get('input_file')} to {options.get('output_file')}"
                )
            logger.info("Conversion completed successfully")

        except Exception as e:
            logger.error("Error during conversion: %s", e, exc_info=True)
            print(f"Error: {e}", file=sys.stderr)
            sys.exit(1)

    elif options.get("command") == "cat":
        verbose_mode = options.get("verbose", False) or options.get("debug", False)
        logger.info("Reading BGFA file from %s", options.get("input_file"))
        gfa = GFA.from_bgfa(
            options.get("input_file"),
            verbose=verbose_mode,
            debug=options.get("debug", False),
            logfile=options.get("logfile"),
        )

        # Output to stdout or file
        output_file = options.get("output")
        if output_file:
            logger.info("Writing GFA output to file: %s", output_file)
            with open(output_file, "w") as f:
                f.write(gfa.to_gfa())
        else:
            logger.info("Writing GFA output to stdout")
            print(gfa.to_gfa())
        logger.info("Cat command completed successfully")

    elif options.get("command") == "measure":
        try:
            logger.info("Measuring BGFA file: %s", options.get("input_file"))
            measure_bgfa(options.get("input_file"), options.get("output_file"))
            logger.info("Measure command completed successfully")
        except Exception as e:
            logger.error("Error during measurement: %s", e, exc_info=True)
            print(f"Error: {e}", file=sys.stderr)
            sys.exit(1)

    elif options.get("command") == "show-full-encodings":
        print(json.dumps(show_full_encodings(), indent=2))

    else:
        # No command specified
        logger.error("No command specified. Use 'bgfa', 'cat', 'measure', or 'show-full-encodings'.")
        print("Error: No command specified. Use 'bgfa', 'cat', 'measure', or 'show-full-encodings'.", file=sys.stderr)
        sys.exit(1)
