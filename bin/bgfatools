#!/usr/bin/env python3
"""
bgfatools - Command line tool for working with BGFA files
"""

import sys
import argparse
import os
import tomllib
import logging
import tempfile
from pygfa.gfa import GFA
from pygfa.encoding.enums import IntegerEncoding, StringEncoding


INT_ENCODING_NAMES = {v.value: v.name.lower() for v in IntegerEncoding}
STR_ENCODING_NAMES = {v.value: v.name.lower() for v in StringEncoding}


def get_int_encoding_name(code):
    """Map integer encoding code to name."""
    return INT_ENCODING_NAMES.get(code, f"0x{code:02x}")


def get_str_encoding_name(code):
    """Map string encoding code to name."""
    return STR_ENCODING_NAMES.get(code, f"0x{code:02x}")


PARAM_COLUMNS = [
    "param_segment_names_header", "param_segment_names_payload_lengths", "param_segment_names_payload_names",
    "param_segments_header", "param_segments_payload_lengths", "param_segments_payload_strings",
    "param_links_header", "param_links_payload_from", "param_links_payload_to",
    "param_links_payload_cigar_lengths", "param_links_payload_cigar",
    "param_paths_header", "param_paths_payload_names", "param_paths_payload_segment_lengths",
    "param_paths_payload_path_ids", "param_paths_payload_cigar_lengths", "param_paths_payload_cigar",
    "param_walks_header", "param_walks_payload_sample_ids", "param_walks_payload_hep_indices",
    "param_walks_payload_sequence_ids", "param_walks_payload_start", "param_walks_payload_end",
    "param_walks_payload_walks",
]


def get_group_args(parser, group_name, parsed_args):
    """Extracts only the arguments belonging to a specific group."""
    arg_group = None
    for g in parser._action_groups:
        if g.title == group_name:
            arg_group = g
            break
    if arg_group is None:
        return {}

    group_dict = {}
    for action in arg_group._group_actions:
        # Skip actions that don't have a dest attribute
        if hasattr(action, "dest") and action.dest:
            if hasattr(parsed_args, action.dest):
                group_dict[action.dest] = getattr(parsed_args, action.dest)
    return group_dict


def parse_cli_options():
    """Parse the command line, returns an options, positional_arguments, compression_options dicts"""
    options = {}
    parser = argparse.ArgumentParser(
        description="Tool for converting between GFA and BGFA formats", prog="bgfatools"
    )
    subparsers = parser.add_subparsers(dest="command", help="Subcommands")

    # bgfa subcommand
    bgfa_parser = subparsers.add_parser("bgfa", help="Convert GFA to BGFA format")
    bgfa_parser.add_argument("input_file", help="Path to input GFA file")
    bgfa_parser.add_argument("output_file", help="Path to output BGFA file")
    bgfa_parser.add_argument(
        "--block-size",
        type=int,
        default=1024,
        help="Block size for BGFA format (default: 1024)",
    )
    bgfa_parser.add_argument(
        "--verbose", "-v", action="store_true", help="Enable verbose output"
    )
    bgfa_parser.add_argument(
        "--config", "-c", type=str, help="Path to TOML configuration file"
    )
    # create the dictionary integers_encoding where the keys are all
    # possible functions to encode a list of integers, taken from gfa.py
    integers_encoding = {
        "none": "compress_integer_list_none",
        "varint": "compress_integer_list_varint",
        "fixed16": "compress_integer_list_fixed",
        "fixed32": "compress_integer_list_fixed",
        "fixed64": "compress_integer_list_fixed",
        "delta": "compress_integer_list_delta",
        "gamma": "compress_integer_list_elias_gamma",
        "omega": "compress_integer_list_elias_omega",
        "golomb": "compress_integer_list_golomb",
        "rice": "compress_integer_list_rice",
        "streamvbyte": "compress_integer_list_streamvbyte",
        "vbyte": "compress_integer_list_vbyte",
        "pfor_delta": "compress_integer_list_pfor_delta",
        "simple8b": "compress_integer_list_simple8b",
        "group_varint": "compress_integer_list_group_varint",
        "bit_packing": "compress_integer_list_bitpacking",
        "fibonacci": "compress_integer_list_fibonacci",
        "exp_golomb": "compress_integer_list_exp_golomb",
        "byte_packed": "compress_integer_list_byte_packed",
        "masked_vbyte": "compress_integer_list_masked_vbyte",
        "": "compress_integer_list_none",
    }
    integers_encoding_str = (
        f" possible values: {'/'.join(integers_encoding.keys())[:-1]}"
    )
    # create the dictionary string_encoding where the keys are all
    # possible functions to encode a string, taken from gfa.py
    string_encoding = {
        "none": "compress_string_none",
        "zstd": "compress_string_zstd",
        "zstd_dict": "compress_string_zstd_dict",
        "gzip": "compress_string_gzip",
        "lzma": "compress_string_lzma",
        "lz4": "compress_string_lz4",
        "brotli": "compress_string_brotli",
        "huffman": "compress_string_list_huffman",
        "frontcoding": "compress_string_list_frontcoding",
        "delta": "compress_string_list_delta",
        "dictionary": "compress_string_list_dictionary",
        "rle": "compress_string_rle",
        "cigar": "compress_string_cigar",
        "2bit": "compress_string_2bit_dna",
        "arithmetic": "compress_string_arithmetic",
        "bwt_huffman": "compress_string_bwt_huffman",
        "ppm": "compress_string_ppm",
        "": "compress_string_none",
    }
    string_encoding_str = f" possible values: {'/'.join(string_encoding.keys())[:-1]}"

    # Compression method options for each component
    compression_group = bgfa_parser.add_argument_group("Compression Options")
    compression_group.add_argument(
        "--segment-names-header",
        type=str,
        default="",
        help="Compression method for segment names header (default: '')"
        + string_encoding_str,
    )
    compression_group.add_argument(
        "--segment-names-payload-lengths",
        type=str,
        default="",
        help="Compression method for segment names payload lengths (default: '')",
    )
    compression_group.add_argument(
        "--segment-names-payload-names",
        type=str,
        default="",
        help="Compression method for segment names payload names (default: '')"
        + string_encoding_str,
    )
    compression_group.add_argument(
        "--segments-header",
        type=str,
        default="",
        help="Compression method for segments header (default: '')"
        + string_encoding_str,
    )
    compression_group.add_argument(
        "--segments-payload-lengths",
        type=str,
        default="",
        help="Compression method for segments payload lengths (default: '')",
    )
    compression_group.add_argument(
        "--segments-payload-strings",
        type=str,
        default="",
        help="Compression method for segments payload strings (default: '')"
        + string_encoding_str,
    )
    compression_group.add_argument(
        "--links-header",
        type=str,
        default="",
        help="Compression method for links header (default: '')",
    )
    compression_group.add_argument(
        "--links-payload-from",
        type=str,
        default="",
        help="Compression method for links payload from (default: '')",
    )
    compression_group.add_argument(
        "--links-payload-to",
        type=str,
        default="",
        help="Compression method for links payload to (default: '')",
    )
    compression_group.add_argument(
        "--links-payload-cigar-lengths",
        type=str,
        default="",
        help="Compression method for links payload cigar lengths (default: '')",
    )
    compression_group.add_argument(
        "--links-payload-cigar",
        type=str,
        default="",
        help="Compression method for links payload cigar (default: '')",
    )
    compression_group.add_argument(
        "--paths-header",
        type=str,
        default="",
        help="Compression method for paths header (default: '')",
    )
    compression_group.add_argument(
        "--paths-payload-names",
        type=str,
        default="",
        help="Compression method for paths payload names (default: '')",
    )
    compression_group.add_argument(
        "--paths-payload-segment-lengths",
        type=str,
        default="",
        help="Compression method for paths payload segment lengths (default: '')",
    )
    compression_group.add_argument(
        "--paths-payload-path-ids",
        type=str,
        default="",
        help=f"Compression method for paths payload path ids (default: ''), possible values: {'/'.join(string_encoding.keys())}",
    )
    compression_group.add_argument(
        "--paths-payload-cigar-lengths",
        type=str,
        default="",
        help="Compression method for paths payload cigar lengths (default: '')",
    )
    compression_group.add_argument(
        "--paths-payload-cigar",
        type=str,
        default="",
        help="Compression method for paths payload cigar (default: '')",
    )
    compression_group.add_argument(
        "--walks-header",
        type=str,
        default="",
        help="Compression method for walks header (default: '')",
    )
    compression_group.add_argument(
        "--walks-payload-sample-ids",
        type=str,
        default="",
        help="Compression method for walks payload sample ids (default: '')",
    )
    compression_group.add_argument(
        "--walks-payload-hep-indices",
        type=str,
        default="",
        help="Compression method for walks payload hep indices (default: '')",
    )
    compression_group.add_argument(
        "--walks-payload-sequence-ids",
        type=str,
        default="",
        help="Compression method for walks payload sequence ids (default: '')",
    )
    compression_group.add_argument(
        "--walks-payload-start",
        type=str,
        default="",
        help="Compression method for walks payload start (default: '')",
    )
    compression_group.add_argument(
        "--walks-payload-end",
        type=str,
        default="",
        help="Compression method for walks payload end (default: '')",
    )
    compression_group.add_argument(
        "--walks-payload-walks",
        type=str,
        default="",
        help="Compression method for walks payload walks (default: '')",
    )

    # cat subcommand
    cat_parser = subparsers.add_parser(
        "cat", help="Convert BGFA to GFA format and output to stdout"
    )
    cat_parser.add_argument("input_file", help="Path to input BGFA file")
    cat_parser.add_argument(
        "--output", "-o", type=str, help="Output file (default: stdout)"
    )

    # measure subcommand
    measure_parser = subparsers.add_parser(
        "measure", help="Analyze BGFA file structure and output block statistics to CSV"
    )
    measure_parser.add_argument("input_file", help="Path to input BGFA file")
    measure_parser.add_argument("output_file", help="Path to output CSV file")
    measure_parser.add_argument(
        "--original-gfa", type=str, help="Path to original GFA file (for reference in output)"
    )

    # Options common to all commands
    parser.add_argument(
        "--verbose",
        "-v",
        action="store_true",
        help="Enable verbose output (INFO level)",
    )
    parser.add_argument(
        "--debug",
        "-d",
        action="store_true",
        help="Enable debug output (more detailed than verbose)",
    )
    parser.add_argument(
        "--logfile",
        "-l",
        type=str,
        help="Path to log file (if not specified and verbose/debug=True, uses a temporary file)",
    )
    parser.add_argument(
        "--config", "-c", type=str, help="Path to TOML configuration file"
    )
    # Add all options to the help output
    parser.add_argument(
        "--help-all", action="store_true", help="Show all options in help output"
    )

    # Parse arguments
    try:
        args = parser.parse_args()
    except SystemExit:
        # argparse will call sys.exit() on error, so we catch it
        sys.exit(1)

    # The actual group titles in argparse might be different
    # Let's manually extract what we need
    options = {}
    compression_options = {}

    # Extract known options
    if hasattr(args, "command"):
        options["command"] = args.command
    if hasattr(args, "block_size"):
        options["block_size"] = args.block_size
    if hasattr(args, "verbose"):
        options["verbose"] = args.verbose
    if hasattr(args, "debug"):
        options["debug"] = args.debug
    if hasattr(args, "logfile"):
        options["logfile"] = args.logfile
    if hasattr(args, "config"):
        options["config"] = args.config
    if hasattr(args, "output"):
        options["output"] = args.output
    if hasattr(args, "original_gfa"):
        options["original_gfa"] = args.original_gfa

    # Extract positional arguments and save them to the options dict
    if hasattr(args, "input_file"):
        options["input_file"] = args.input_file
    if hasattr(args, "output_file"):
        options["output_file"] = args.output_file

    # Extract compression options (they have specific names)
    comp_prefixes = [
        "segment_names_header",
        "segment_names_payload_lengths",
        "segment_names_payload_names",
        "segments_header",
        "segments_payload_lengths",
        "segments_payload_strings",
        "links_header",
        "links_payload_from",
        "links_payload_to",
        "links_payload_cigar_lengths",
        "links_payload_cigar",
        "paths_header",
        "paths_payload_names",
        "paths_payload_segment_lengths",
        "paths_payload_path_ids",
        "paths_payload_cigar_lengths",
        "paths_payload_cigar",
        "walks_header",
        "walks_payload_sample_ids",
        "walks_payload_hep_indices",
        "walks_payload_sequence_ids",
        "walks_payload_start",
        "walks_payload_end",
        "walks_payload_walks",
    ]

    for prefix in comp_prefixes:
        attr_name = prefix.replace("-", "_")
        if hasattr(args, attr_name):
            compression_options[prefix] = getattr(args, attr_name)

    # Load configuration from TOML file if provided
    config = {}
    if args.config:
        if not os.path.exists(args.config):
            print(
                f"Error: Configuration file '{args.config}' not found", file=sys.stderr
            )
            sys.exit(1)

        try:
            with open(args.config, "rb") as f:
                config = tomllib.load(f)
        except ValueError as e:
            print(
                f"Error: Invalid TOML format in '{args.config}': {e}", file=sys.stderr
            )
            sys.exit(1)
        except Exception as e:
            print(
                f"Error: Failed to read configuration file '{args.config}': {e}",
                file=sys.stderr,
            )
            sys.exit(1)

    # Merge command line arguments with configuration file values
    for opt in compression_options.keys():
        if opt in config:
            compression_options[opt] = config[opt]
    for opt in options.keys():
        if opt in config:
            options[opt] = config[opt]
    # Validate compression methods
    for component, method in compression_options.items():
        if method and method not in integers_encoding and method not in string_encoding:
            print(
                f"Error: Invalid compression method '{method}' for {component}. "
                f"Valid methods are: {list(integers_encoding.keys()) + list(string_encoding.keys())}",
                file=sys.stderr,
            )
            sys.exit(1)

    return options, compression_options


def measure_bgfa(input_file: str, output_file: str, original_gfa: str = ""):
    """Analyze BGFA file structure and output block statistics to CSV.
    
    :param input_file: Path to input BGFA file
    :param output_file: Path to output CSV file
    :param original_gfa: Path to original GFA file
    """
    import csv
    import struct
    import math
    from pygfa.utils.file_opener import open_gfa_file
    
    # Read BGFA file
    with open_gfa_file(input_file, "rb") as f:
        bgfa_data = f.read()
    
    rows = []
    offset = 0
    filename = os.path.basename(input_file)
    original_gfa_path = original_gfa if original_gfa else ""

    def create_base_row():
        """Create a row dict with all common fields and empty param columns."""
        row = {
            "original_gfa": original_gfa_path,
            "filename": filename,
            "block_type": "",
            "block_index": 0,
            "block_size": block_size,
            "record_count": 0,
            "offset_start": 0,
            "offset_end": 0,
            "size_bytes": 0,
            "compression_ratio": "",
            "version": "",
            "s_len": "",
            "l_len": "",
            "p_len": "",
            "w_len": "",
            "header_text": "",
            "encoding_high": "",
            "encoding_low": "",
            "compressed_size": 0,
            "uncompressed_size": 0,
        }
        for col in PARAM_COLUMNS:
            row[col] = ""
        return row
    
    # Parse header
    header_start = 0
    
    # Read version (uint16)
    version = struct.unpack_from("<H", bgfa_data, offset)[0]
    offset += 2
    
    # Read block_size (uint16)
    block_size = struct.unpack_from("<H", bgfa_data, offset)[0]
    offset += 2
    
    # Read counts (uint64)
    s_len = struct.unpack_from("<Q", bgfa_data, offset)[0]
    offset += 8
    l_len = struct.unpack_from("<Q", bgfa_data, offset)[0]
    offset += 8
    p_len = struct.unpack_from("<Q", bgfa_data, offset)[0]
    offset += 8
    w_len = struct.unpack_from("<Q", bgfa_data, offset)[0]
    offset += 8
    
    # Read header text (C string)
    header_text = ""
    while offset < len(bgfa_data) and bgfa_data[offset] != 0:
        header_text += chr(bgfa_data[offset])
        offset += 1
    offset += 1  # Skip null terminator
    
    header_end = offset
    
    # Add header row
    rows.append({
        "original_gfa": original_gfa_path,
        "filename": filename,
        "block_type": "header",
        "block_index": 0,
        "block_size": block_size,
        "record_count": "",
        "offset_start": header_start,
        "offset_end": header_end,
        "size_bytes": header_end - header_start,
        "compression_ratio": "",
        "version": version,
        "s_len": s_len,
        "l_len": l_len,
        "p_len": p_len,
        "w_len": w_len,
        "header_text": header_text,
        "encoding_high": "",
        "encoding_low": "",
        "compressed_size": header_end - header_start,
        "uncompressed_size": header_end - header_start,
    })
    
    # Parse segment names blocks
    num_blocks = math.ceil(s_len / block_size) if block_size > 0 else 0
    for block_idx in range(num_blocks):
        block_start = offset
        
        # Read block header
        record_num = struct.unpack_from("<H", bgfa_data, offset)[0]
        offset += 2
        compression_names = struct.unpack_from("<H", bgfa_data, offset)[0]
        offset += 2
        compressed_len = struct.unpack_from("<Q", bgfa_data, offset)[0]
        offset += 8
        uncompressed_len = struct.unpack_from("<Q", bgfa_data, offset)[0]
        offset += 8
        
        # Skip payload
        offset += compressed_len
        block_end = offset
        
        # Calculate compression ratio
        ratio = compressed_len / uncompressed_len if uncompressed_len > 0 else 0
        
        # Extract encoding
        int_encoding = (compression_names >> 8) & 0xFF
        str_encoding = compression_names & 0xFF

        row = create_base_row()
        row["block_type"] = "segment_names"
        row["block_index"] = block_idx
        row["record_count"] = record_num
        row["offset_start"] = block_start
        row["offset_end"] = block_end
        row["size_bytes"] = block_end - block_start
        row["compression_ratio"] = f"{ratio:.4f}"
        row["encoding_high"] = f"0x{int_encoding:02x}"
        row["encoding_low"] = f"0x{str_encoding:02x}"
        row["compressed_size"] = compressed_len
        row["uncompressed_size"] = uncompressed_len
        row["param_segment_names_payload_lengths"] = get_int_encoding_name(int_encoding)
        row["param_segment_names_payload_names"] = get_str_encoding_name(str_encoding)
        rows.append(row)
    
    # Parse segments blocks
    num_blocks = math.ceil(s_len / block_size) if block_size > 0 else 0
    for block_idx in range(num_blocks):
        block_start = offset
        
        # Read block header
        record_num = struct.unpack_from("<H", bgfa_data, offset)[0]
        offset += 2
        compression_str = struct.unpack_from("<H", bgfa_data, offset)[0]
        offset += 2
        compressed_len = struct.unpack_from("<Q", bgfa_data, offset)[0]
        offset += 8
        uncompressed_len = struct.unpack_from("<Q", bgfa_data, offset)[0]
        offset += 8
        
        # Skip payload
        offset += compressed_len
        block_end = offset
        
        # Calculate compression ratio
        ratio = compressed_len / uncompressed_len if uncompressed_len > 0 else 0
        
        # Extract encoding
        int_encoding = (compression_str >> 8) & 0xFF
        str_encoding = compression_str & 0xFF

        row = create_base_row()
        row["block_type"] = "segments"
        row["block_index"] = block_idx
        row["record_count"] = record_num
        row["offset_start"] = block_start
        row["offset_end"] = block_end
        row["size_bytes"] = block_end - block_start
        row["compression_ratio"] = f"{ratio:.4f}"
        row["encoding_high"] = f"0x{int_encoding:02x}"
        row["encoding_low"] = f"0x{str_encoding:02x}"
        row["compressed_size"] = compressed_len
        row["uncompressed_size"] = uncompressed_len
        row["param_segments_payload_lengths"] = get_int_encoding_name(int_encoding)
        row["param_segments_payload_strings"] = get_str_encoding_name(str_encoding)
        rows.append(row)
    
    # Parse links blocks
    num_blocks = math.ceil(l_len / block_size) if block_size > 0 else 0
    for block_idx in range(num_blocks):
        block_start = offset
        
        # Read block header
        record_num = struct.unpack_from("<H", bgfa_data, offset)[0]
        offset += 2
        compression_fromto = struct.unpack_from("<H", bgfa_data, offset)[0]
        offset += 2
        compression_cigars = struct.unpack_from("<H", bgfa_data, offset)[0]
        offset += 2
        compressed_len = struct.unpack_from("<Q", bgfa_data, offset)[0]
        offset += 8
        uncompressed_len = struct.unpack_from("<Q", bgfa_data, offset)[0]
        offset += 8
        
        # Skip payload
        offset += compressed_len
        block_end = offset
        
        # Calculate compression ratio
        ratio = compressed_len / uncompressed_len if uncompressed_len > 0 else 0
        
        # Extract encodings
        int_fromto = (compression_fromto >> 8) & 0xFF
        int_cigars = (compression_cigars >> 8) & 0xFF
        str_cigars = compression_cigars & 0xFF

        row = create_base_row()
        row["block_type"] = "links"
        row["block_index"] = block_idx
        row["record_count"] = record_num
        row["offset_start"] = block_start
        row["offset_end"] = block_end
        row["size_bytes"] = block_end - block_start
        row["compression_ratio"] = f"{ratio:.4f}"
        row["encoding_high"] = f"0x{int_fromto:02x}"
        row["encoding_low"] = f"0x{str_cigars:02x}"
        row["compressed_size"] = compressed_len
        row["uncompressed_size"] = uncompressed_len
        row["param_links_payload_from"] = get_int_encoding_name(int_fromto)
        row["param_links_payload_to"] = get_int_encoding_name(int_fromto)
        row["param_links_payload_cigar_lengths"] = get_int_encoding_name(int_cigars)
        row["param_links_payload_cigar"] = get_str_encoding_name(str_cigars)
        rows.append(row)
    
    # Parse paths blocks (if present)
    if p_len > 0:
        num_blocks = math.ceil(p_len / block_size) if block_size > 0 else 0
        for block_idx in range(num_blocks):
            block_start = offset
            
            # Paths have 3 compression codes (uint16 each) + 4 length fields (per spec)
            record_num = struct.unpack_from("<H", bgfa_data, offset)[0]
            offset += 2
            compression_names = struct.unpack_from("<H", bgfa_data, offset)[0]
            offset += 2
            compression_paths = struct.unpack_from("<H", bgfa_data, offset)[0]
            offset += 2
            compression_cigars = struct.unpack_from("<H", bgfa_data, offset)[0]
            offset += 2
            # 4 length fields: compressed_len_cigar, uncompressed_len_cigar, compressed_len_name, uncompressed_len_name
            compressed_len_cigar = struct.unpack_from("<Q", bgfa_data, offset)[0]
            offset += 8
            uncompressed_len_cigar = struct.unpack_from("<Q", bgfa_data, offset)[0]
            offset += 8
            compressed_len_name = struct.unpack_from("<Q", bgfa_data, offset)[0]
            offset += 8
            uncompressed_len_name = struct.unpack_from("<Q", bgfa_data, offset)[0]
            offset += 8

            # Skip payloads
            offset += compressed_len_cigar
            offset += compressed_len_name
            block_end = offset

            # Calculate compression ratio (use cigar for ratio)
            total_compressed = compressed_len_cigar + compressed_len_name
            total_uncompressed = uncompressed_len_cigar + uncompressed_len_name
            ratio = total_compressed / total_uncompressed if total_uncompressed > 0 else 0

            # Extract encodings
            str_names = compression_names & 0xFF
            int_paths = (compression_paths >> 8) & 0xFF
            str_paths = compression_paths & 0xFF
            int_cigars = (compression_cigars >> 8) & 0xFF
            str_cigars = compression_cigars & 0xFF

            row = create_base_row()
            row["block_type"] = "paths"
            row["block_index"] = block_idx
            row["record_count"] = record_num
            row["offset_start"] = block_start
            row["offset_end"] = block_end
            row["size_bytes"] = block_end - block_start
            row["compression_ratio"] = f"{ratio:.4f}"
            row["encoding_high"] = f"0x{int_paths:02x}"
            row["encoding_low"] = f"0x{str_cigars:02x}"
            row["compressed_size"] = total_compressed
            row["uncompressed_size"] = total_uncompressed
            row["param_paths_payload_names"] = get_str_encoding_name(str_names)
            row["param_paths_payload_path_ids"] = f"{get_int_encoding_name(int_paths)}_{get_str_encoding_name(str_paths)}"
            row["param_paths_payload_cigar_lengths"] = get_int_encoding_name(int_cigars)
            row["param_paths_payload_cigar"] = get_str_encoding_name(str_cigars)
            rows.append(row)
    
    # Parse walks blocks (if present)
    if w_len > 0:
        num_blocks = math.ceil(w_len / block_size) if block_size > 0 else 0
        for block_idx in range(num_blocks):
            block_start = offset
            
            # Walks have 5 compression codes + 6 length fields per spec
            record_num = struct.unpack_from("<H", bgfa_data, offset)[0]
            offset += 2
            # Read 5 compression codes
            compression_samples = struct.unpack_from("<H", bgfa_data, offset)[0]
            offset += 2
            compression_hep = struct.unpack_from("<H", bgfa_data, offset)[0]
            offset += 2
            compression_sequence = struct.unpack_from("<H", bgfa_data, offset)[0]
            offset += 2
            compression_positions = struct.unpack_from("<H", bgfa_data, offset)[0]
            offset += 2
            compression_walks = struct.unpack_from("<H", bgfa_data, offset)[0]
            offset += 2
            # Read 6 length fields
            compressed_len_sam = struct.unpack_from("<Q", bgfa_data, offset)[0]
            offset += 8
            uncompressed_len_sam = struct.unpack_from("<Q", bgfa_data, offset)[0]
            offset += 8
            compressed_len_seq = struct.unpack_from("<Q", bgfa_data, offset)[0]
            offset += 8
            uncompressed_len_seq = struct.unpack_from("<Q", bgfa_data, offset)[0]
            offset += 8
            compressed_len_walk = struct.unpack_from("<Q", bgfa_data, offset)[0]
            offset += 8
            uncompressed_len_walk = struct.unpack_from("<Q", bgfa_data, offset)[0]
            offset += 8

            # Skip payloads
            offset += compressed_len_sam
            offset += compressed_len_seq
            offset += compressed_len_walk
            block_end = offset

            # Calculate compression ratio
            total_compressed = compressed_len_sam + compressed_len_seq + compressed_len_walk
            total_uncompressed = uncompressed_len_sam + uncompressed_len_seq + uncompressed_len_walk
            ratio = total_compressed / total_uncompressed if total_uncompressed > 0 else 0

            # Extract encodings
            str_samples = compression_samples & 0xFF
            int_hep = (compression_hep >> 8) & 0xFF
            str_seq = compression_sequence & 0xFF
            int_positions = (compression_positions >> 8) & 0xFF
            int_walks = (compression_walks >> 8) & 0xFF
            str_walks = compression_walks & 0xFF

            row = create_base_row()
            row["block_type"] = "walks"
            row["block_index"] = block_idx
            row["record_count"] = record_num
            row["offset_start"] = block_start
            row["offset_end"] = block_end
            row["size_bytes"] = block_end - block_start
            row["compression_ratio"] = f"{ratio:.4f}"
            row["encoding_high"] = f"0x{int_walks:02x}"
            row["encoding_low"] = f"0x{str_walks:02x}"
            row["compressed_size"] = total_compressed
            row["uncompressed_size"] = total_uncompressed
            row["param_walks_payload_sample_ids"] = get_str_encoding_name(str_samples)
            row["param_walks_payload_hep_indices"] = get_int_encoding_name(int_hep)
            row["param_walks_payload_sequence_ids"] = get_str_encoding_name(str_seq)
            row["param_walks_payload_start"] = get_int_encoding_name(int_positions)
            row["param_walks_payload_end"] = get_int_encoding_name(int_positions)
            row["param_walks_payload_walks"] = f"{get_int_encoding_name(int_walks)}_{get_str_encoding_name(str_walks)}"
            rows.append(row)

    # Write CSV output
    fieldnames = [
        "original_gfa", "filename", "block_type", "block_index", "block_size", "record_count",
        "offset_start", "offset_end", "size_bytes", "compression_ratio",
        "version", "s_len", "l_len", "p_len", "w_len", "header_text",
        "encoding_high", "encoding_low", "compressed_size", "uncompressed_size",
    ] + PARAM_COLUMNS
    
    with open(output_file, "w", newline="") as csvfile:
        writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
        writer.writeheader()
        writer.writerows(rows)
    
    print(f"Successfully wrote measurements to {output_file}")
    print(f"Analyzed {len(rows)} blocks total")


if __name__ == "__main__":
    import sys

    options, compression_options = parse_cli_options()

    # Check if we got the required data
    if not options:
        print("Error: Failed to parse command line options.", file=sys.stderr)
        sys.exit(1)

    # Determine log level
    if options.get("debug"):
        log_level = logging.DEBUG
    elif options.get("verbose"):
        log_level = logging.INFO
    else:
        log_level = logging.WARNING

    # If logfile is not provided, create a temporary one
    logfile = options.get("logfile")
    if logfile is None:
        temp_log = tempfile.NamedTemporaryFile(mode="w", delete=False, suffix=".log")
        logfile = temp_log.name
        temp_log.close()
        print(f"Logging to temporary file: {logfile}")

    # Clear any existing handlers
    logging.getLogger().handlers.clear()

    # Create formatter
    formatter = logging.Formatter(
        "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
    )

    # Create file handler
    file_handler = logging.FileHandler(logfile)
    file_handler.setLevel(log_level)
    file_handler.setFormatter(formatter)

    # Create stream handler (console)
    stream_handler = logging.StreamHandler()
    stream_handler.setLevel(log_level)
    stream_handler.setFormatter(formatter)

    # Configure root logger
    logging.basicConfig(level=log_level, handlers=[file_handler, stream_handler])

    logger = logging.getLogger(__name__)
    logger.info("Starting bgfatools command: %s", options.get("command"))

    if options.get("command") == "bgfa":
        try:
            # Build compression options dictionary
            comp_dict = {}
            # Add all compression methods to the options
            for key, value in compression_options.items():
                comp_dict[key] = value

            # Read GFA file
            logger.info("Reading GFA file from %s", options.get("input_file"))
            g = GFA.from_gfa(options.get("input_file"))

            # Write BGFA file
            logger.info("Writing BGFA file to %s", options.get("output_file"))
            verbose_mode = options.get("verbose", False) or options.get("debug", False)
            g.to_bgfa(
                options.get("output_file"),
                options.get("block_size", 1024),
                comp_dict,
                verbose=verbose_mode,
                debug=options.get("debug", False),
                logfile=options.get("logfile"),
            )

            if options.get("verbose"):
                print(
                    f"Successfully converted {options.get('input_file')} to {options.get('output_file')}"
                )
            logger.info("Conversion completed successfully")

        except Exception as e:
            logger.error("Error during conversion: %s", e, exc_info=True)
            print(f"Error: {e}", file=sys.stderr)
            sys.exit(1)

    elif options.get("command") == "cat":
        verbose_mode = options.get("verbose", False) or options.get("debug", False)
        logger.info("Reading BGFA file from %s", options.get("input_file"))
        gfa = GFA.from_bgfa(
            options.get("input_file"),
            verbose=verbose_mode,
            debug=options.get("debug", False),
            logfile=options.get("logfile"),
        )

        # Output to stdout or file
        output_file = options.get("output")
        if output_file:
            logger.info("Writing GFA output to file: %s", output_file)
            with open(output_file, "w") as f:
                f.write(gfa.to_gfa())
        else:
            logger.info("Writing GFA output to stdout")
            print(gfa.to_gfa())
        logger.info("Cat command completed successfully")

    elif options.get("command") == "measure":
        try:
            logger.info("Measuring BGFA file: %s", options.get("input_file"))
            original_gfa = options.get("original_gfa", "")
            measure_bgfa(options.get("input_file"), options.get("output_file"), original_gfa)
            logger.info("Measure command completed successfully")
        except Exception as e:
            logger.error("Error during measurement: %s", e, exc_info=True)
            print(f"Error: {e}", file=sys.stderr)
            sys.exit(1)

    else:
        # No command specified
        logger.error("No command specified. Use 'bgfa', 'cat', or 'measure'.")
        print("Error: No command specified. Use 'bgfa' or 'cat'.", file=sys.stderr)
        sys.exit(1)
