#!/usr/bin/env python3
"""
bgfatools - Command line tool for working with BGFA files
"""

import sys
import argparse
import os
import tomllib
import logging
import json
from pygfa.gfa import GFA
from pygfa.encoding import (
    show_full_encodings,
)
from pygfa.bgfa import measure_bgfa, validate_bgfa


def parse_cli_options():
    """Parse the command line, returns an options dict"""
    options = {}
    parser = argparse.ArgumentParser(
        description="Tool for converting between GFA and BGFA formats", prog="bgfatools"
    )
    subparsers = parser.add_subparsers(dest="command", help="Subcommands")

    # bgfa subcommand
    bgfa_parser = subparsers.add_parser("bgfa", help="Convert GFA to BGFA format")
    bgfa_parser.add_argument("input_file", help="Path to input GFA file")
    bgfa_parser.add_argument("output_file", help="Path to output BGFA file")
    bgfa_parser.add_argument(
        "--block-size",
        type=int,
        default=1024,
        help="Block size for BGFA format (default: 1024)",
    )
    bgfa_parser.add_argument(
        "--verbose", "-v", action="store_true", help="Enable verbose output"
    )
    bgfa_parser.add_argument(
        "--config", "-c", type=str, help="Path to TOML configuration file"
    )

    # Strategy options for every component
    strategy_group = bgfa_parser.add_argument_group("Strategy Options (Format: int+str, e.g. varint+huffman, varint+2bit)")
    strategy_group.add_argument("--segment-names", type=str, default="varint+none")
    strategy_group.add_argument("--compression-segment-names", type=str, default="varint+none")
    strategy_group.add_argument("--sequences", type=str, default="varint+none")
    strategy_group.add_argument("--compression-sequences", type=str, default="varint+none")
    strategy_group.add_argument("--link-endpoints", type=str, default="varint+none")
    strategy_group.add_argument("--compression-link-endpoints", type=str, default="varint+none")
    strategy_group.add_argument("--link-cigars", type=str, default="varint+none")
    strategy_group.add_argument("--compression-link-cigars", type=str, default="varint+none")
    strategy_group.add_argument("--path-names", type=str, default="varint+none")
    strategy_group.add_argument("--compression-path-names", type=str, default="varint+none")
    strategy_group.add_argument("--path-sequences", type=str, default="varint+none")
    strategy_group.add_argument("--compression-path-sequences", type=str, default="varint+none")
    strategy_group.add_argument("--path-cigars", type=str, default="varint+none")
    strategy_group.add_argument("--compression-path-cigars", type=str, default="varint+none")
    strategy_group.add_argument("--walk-sample-ids", type=str, default="varint+none")
    strategy_group.add_argument("--compression-walk-sample-ids", type=str, default="varint+none")
    strategy_group.add_argument("--walk-haplotype-indices", type=str, default="varint+none")
    strategy_group.add_argument("--compression-walk-haplotype-indices", type=str, default="varint+none")
    strategy_group.add_argument("--walk-sequence-ids", type=str, default="varint+none")
    strategy_group.add_argument("--compression-walk-sequence-ids", type=str, default="varint+none")
    strategy_group.add_argument("--walk-positions-start", type=str, default="varint+none")
    strategy_group.add_argument("--compression-walk-positions-start", type=str, default="varint+none")
    strategy_group.add_argument("--walk-positions-end", type=str, default="varint+none")
    strategy_group.add_argument("--compression-walk-positions-end", type=str, default="varint+none")
    strategy_group.add_argument("--walk-steps", type=str, default="varint+none")
    strategy_group.add_argument("--compression-walk-steps", type=str, default="varint+none")

    # cat subcommand

    # cat subcommand
    cat_parser = subparsers.add_parser(
        "cat", help="Convert BGFA to GFA format and output to stdout"
    )
    cat_parser.add_argument("input_file", help="Path to input BGFA file")
    cat_parser.add_argument(
        "--output", "-o", type=str, help="Output file (default: stdout)"
    )

    # measure subcommand
    measure_parser = subparsers.add_parser(
        "measure", help="Analyze BGFA file structure and output block statistics to CSV"
    )
    measure_parser.add_argument("input_file", help="Path to input BGFA file")
    measure_parser.add_argument(
        "--output", "-o", type=str, default=None,
        help="Path to output CSV file (default: /dev/null, --verbose sends to stdout)",
    )
    measure_parser.add_argument(
        "--verbose", "-v", action="store_true", help="Enable verbose output"
    )

    # verify subcommand
    verify_parser = subparsers.add_parser(
        "validate", help="Validate BGFA file structure against specification"
    )
    verify_parser.add_argument("input_file", help="Path to input BGFA file")
    verify_parser.add_argument(
        "--output", "-o", type=str, default=None,
        help="Path to output JSON report file (default: stdout)",
    )
    verify_parser.add_argument(
        "--verbose", "-v", action="store_true", help="Enable verbose output"
    )

    # show-full-encodings subcommand
    subparsers.add_parser(
        "show-full-encodings", help="Show all compression encoding options as JSON"
    )

    # dump subcommand
    dump_parser = subparsers.add_parser(
        "dump", help="Dump BGFA file contents with detailed field information"
    )
    dump_parser.add_argument("input_file", help="Path to input BGFA file")
    dump_parser.add_argument(
        "--output", "-o", type=str, default=None,
        help="Path to output file (default: stdout)",
    )
    dump_parser.add_argument(
        "--text", action="store_true",
        help="Output pretty text format instead of JSON (default: JSON)",
    )
    dump_parser.add_argument(
        "--verbose", "-v", action="store_true", help="Enable verbose output"
    )

    # Options common to all commands
    parser.add_argument(
        "--verbose",
        "-v",
        action="store_true",
        help="Enable verbose output (INFO level)",
    )
    parser.add_argument(
        "--debug",
        "-d",
        action="store_true",
        help="Enable debug output (more detailed than verbose)",
    )
    parser.add_argument(
        "--logfile",
        "-l",
        type=str,
        help="Path to log file (if not specified and verbose/debug=True, uses a temporary file)",
    )
    parser.add_argument(
        "--config", "-c", type=str, help="Path to TOML configuration file"
    )
    # Add all options to the help output
    parser.add_argument(
        "--help-all", action="store_true", help="Show all options in help output"
    )

    # Parse arguments
    try:
        args = parser.parse_args()
    except SystemExit:
        # argparse will call sys.exit() on error, so we catch it
        sys.exit(1)

    # The actual group titles in argparse might be different
    # Let's manually extract what we need
    options = {}

    # Extract known options
    if hasattr(args, "command"):
        options["command"] = args.command
    if hasattr(args, "block_size"):
        options["block_size"] = args.block_size
    if hasattr(args, "verbose"):
        options["verbose"] = args.verbose
    if hasattr(args, "debug"):
        options["debug"] = args.debug
    if hasattr(args, "logfile"):
        options["logfile"] = args.logfile
    if hasattr(args, "config"):
        options["config"] = args.config
    if hasattr(args, "output"):
        options["output"] = args.output
    if hasattr(args, "original_gfa"):
        options["original_gfa"] = args.original_gfa
    if hasattr(args, "text"):
        options["text"] = args.text

    # Extract positional arguments and save them to the options dict
    if hasattr(args, "input_file"):
        options["input_file"] = args.input_file
    if hasattr(args, "output_file"):
        options["output_file"] = args.output_file

    # Extract strategy options for bgfa command (kwargs keys use _enc suffix for writer compatibility)
    # Priority: compression_ options override non-compression_ options for backward compatibility
    if hasattr(args, "compression_segment_names"):
        options["segment_names_enc"] = args.compression_segment_names
    elif hasattr(args, "segment_names"):
        options["segment_names_enc"] = args.segment_names
    
    if hasattr(args, "compression_sequences"):
        options["sequences_enc"] = args.compression_sequences
    elif hasattr(args, "sequences"):
        options["sequences_enc"] = args.sequences
    
    if hasattr(args, "compression_link_endpoints"):
        options["link_endpoints_enc"] = args.compression_link_endpoints
    elif hasattr(args, "link_endpoints"):
        options["link_endpoints_enc"] = args.link_endpoints
    
    if hasattr(args, "compression_link_cigars"):
        options["link_cigars_enc"] = args.compression_link_cigars
    elif hasattr(args, "link_cigars"):
        options["link_cigars_enc"] = args.link_cigars
    
    if hasattr(args, "compression_path_names"):
        options["path_names_enc"] = args.compression_path_names
    elif hasattr(args, "path_names"):
        options["path_names_enc"] = args.path_names
    
    if hasattr(args, "compression_path_sequences"):
        options["path_sequences_enc"] = args.compression_path_sequences
    elif hasattr(args, "path_sequences"):
        options["path_sequences_enc"] = args.path_sequences
    
    if hasattr(args, "compression_path_cigars"):
        options["path_cigars_enc"] = args.compression_path_cigars
    elif hasattr(args, "path_cigars"):
        options["path_cigars_enc"] = args.path_cigars
    
    if hasattr(args, "compression_walk_sample_ids"):
        options["walk_sample_ids_enc"] = args.compression_walk_sample_ids
    elif hasattr(args, "walk_sample_ids"):
        options["walk_sample_ids_enc"] = args.walk_sample_ids
    
    if hasattr(args, "compression_walk_haplotype_indices"):
        options["walk_haplotype_indices_enc"] = args.compression_walk_haplotype_indices
    elif hasattr(args, "walk_haplotype_indices"):
        options["walk_haplotype_indices_enc"] = args.walk_haplotype_indices
    
    if hasattr(args, "compression_walk_sequence_ids"):
        options["walk_sequence_ids_enc"] = args.compression_walk_sequence_ids
    elif hasattr(args, "walk_sequence_ids"):
        options["walk_sequence_ids_enc"] = args.walk_sequence_ids
    
    if hasattr(args, "compression_walk_positions_start"):
        options["walk_positions_start_enc"] = args.compression_walk_positions_start
    elif hasattr(args, "walk_positions_start"):
        options["walk_positions_start_enc"] = args.walk_positions_start
    
    if hasattr(args, "compression_walk_positions_end"):
        options["walk_positions_end_enc"] = args.compression_walk_positions_end
    elif hasattr(args, "walk_positions_end"):
        options["walk_positions_end_enc"] = args.walk_positions_end
    
    if hasattr(args, "compression_walk_steps"):
        options["walk_steps_enc"] = args.compression_walk_steps
    elif hasattr(args, "walk_steps"):
        options["walk_steps_enc"] = args.walk_steps

    # Load configuration from TOML file if provided
    config = {}
    if args.config:
        if not os.path.exists(args.config):
            print(
                f"Error: Configuration file '{args.config}' not found", file=sys.stderr
            )
            sys.exit(1)

        try:
            with open(args.config, "rb") as f:
                config = tomllib.load(f)
        except ValueError as e:
            print(
                f"Error: Invalid TOML format in '{args.config}': {e}", file=sys.stderr
            )
            sys.exit(1)
        except Exception as e:
            print(
                f"Error: Failed to read configuration file '{args.config}': {e}",
                file=sys.stderr,
            )
            sys.exit(1)

    # Merge command line arguments with configuration file values
    for opt in options.keys():
        if opt in config:
            options[opt] = config[opt]

    return options


def log_parsed_options(options, logger):
    """Log the parsed command line options in verbose mode."""
    if not logger or not logger.isEnabledFor(logging.INFO):
        return
    
    logger.info("Parsed command line options:")
    
    # Log basic options
    if "command" in options:
        logger.info("  Command: %s", options["command"])
    if "input_file" in options:
        logger.info("  Input file: %s", options["input_file"])
    if "output_file" in options:
        logger.info("  Output file: %s", options["output_file"])
    if "block_size" in options:
        logger.info("  Block size: %s", options["block_size"])
    if "verbose" in options and options["verbose"]:
        logger.info("  Verbose: True")
    if "debug" in options and options["debug"]:
        logger.info("  Debug: True")
    
    # Log strategy options
    strategy_opts = [
        "segment_names_enc", "sequences_enc", "link_endpoints_enc", "link_cigars_enc",
        "path_names_enc", "path_sequences_enc", "path_cigars_enc",
        "walk_sample_ids_enc", "walk_haplotype_indices_enc", "walk_sequence_ids_enc",
        "walk_positions_start_enc", "walk_positions_end_enc", "walk_steps_enc"
    ]
    
    strategy_opts_found = False
    for opt in strategy_opts:
        if opt in options and options[opt]:
            if not strategy_opts_found:
                logger.info("  Strategy options:")
                strategy_opts_found = True
            logger.info("    %s: %s", opt.replace("_", " "), options[opt])
    
    if "config" in options and options["config"]:
        logger.info("  Config file: %s", options["config"])


if __name__ == "__main__":
    import sys

    options = parse_cli_options()

    # Check if we got the required data
    if not options:
        print("Error: Failed to parse command line options.", file=sys.stderr)
        sys.exit(1)

    # Determine log level
    if options.get("debug"):
        log_level = logging.DEBUG
    elif options.get("verbose"):
        log_level = logging.INFO
    else:
        log_level = logging.WARNING

    logfile = options.get("logfile")

    # Clear any existing handlers
    logging.getLogger().handlers.clear()

    # Create formatter
    formatter = logging.Formatter(
        "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
    )

    # Create stream handler (console)
    stream_handler = logging.StreamHandler()
    stream_handler.setLevel(log_level)
    stream_handler.setFormatter(formatter)

    if logfile:
        file_handler = logging.FileHandler(logfile)
        file_handler.setLevel(log_level)
        file_handler.setFormatter(formatter)
        logging.basicConfig(level=log_level, handlers=[file_handler, stream_handler])
    else:
        logging.basicConfig(level=log_level, handlers=[stream_handler])

    logger = logging.getLogger(__name__)
    logger.info("Starting bgfatools command: %s", options.get("command"))

    # Log parsed options in verbose mode
    if options.get("verbose") or options.get("debug"):
        log_parsed_options(options, logger)

    if options.get("command") == "bgfa":
        try:
            # Read GFA file
            logger.info("Reading GFA file from %s", options.get("input_file"))
            g = GFA.from_gfa(options.get("input_file"))

            # Write BGFA file
            logger.info("Writing BGFA file to %s", options.get("output_file"))
            verbose_mode = options.get("verbose", False) or options.get("debug", False)
            g.to_bgfa(
                options.get("output_file"),
                block_size=options.get("block_size", 1024),
                verbose=verbose_mode,
                debug=options.get("debug", False),
                logfile=options.get("logfile"),
                # Granular strategy options (keys use _enc suffix for writer compatibility)
                segment_names_enc=options.get("segment_names_enc", "varint+none"),
                sequences_enc=options.get("sequences_enc", "varint+2bit"),
                link_endpoints_enc=options.get("link_endpoints_enc", "varint+none"),
                link_cigars_enc=options.get("link_cigars_enc", "varint+none"),
                path_names_enc=options.get("path_names_enc", "varint+none"),
                path_sequences_enc=options.get("path_sequences_enc", "varint+none"),
                path_cigars_enc=options.get("path_cigars_enc", "varint+none"),
                walk_sample_ids_enc=options.get("walk_sample_ids_enc", "varint+none"),
                walk_haplotype_indices_enc=options.get("walk_haplotype_indices_enc", "varint+none"),
                walk_sequence_ids_enc=options.get("walk_sequence_ids_enc", "varint+none"),
                walk_positions_start_enc=options.get("walk_positions_start_enc", "varint+none"),
                walk_positions_end_enc=options.get("walk_positions_end_enc", "varint+none"),
                walk_steps_enc=options.get("walk_steps_enc", "varint+none"),
            )

            if options.get("verbose"):
                print(
                    f"Successfully converted {options.get('input_file')} to {options.get('output_file')}"
                )
            logger.info("Conversion completed successfully")

        except Exception as e:
            logger.error("Error during conversion: %s", e, exc_info=True)
            print(f"Error: {e}", file=sys.stderr)
            sys.exit(1)

    elif options.get("command") == "cat":
        verbose_mode = options.get("verbose", False) or options.get("debug", False)
        logger.info("Reading BGFA file from %s", options.get("input_file"))
        gfa = GFA.from_bgfa(
            options.get("input_file"),
            verbose=verbose_mode,
            debug=options.get("debug", False),
            logfile=options.get("logfile"),
        )

        # Output to stdout or file
        output_file = options.get("output")
        if output_file:
            logger.info("Writing GFA output to file: %s", output_file)
            with open(output_file, "w") as f:
                f.write(gfa.to_gfa())
        else:
            logger.info("Writing GFA output to stdout")
            print(gfa.to_gfa())
        logger.info("Cat command completed successfully")

    elif options.get("command") == "measure":
        try:
            logger.info("Measuring BGFA file: %s", options.get("input_file"))
            verbose_mode = options.get("verbose", False) or options.get("debug", False)
            output_file = options.get("output")
            if output_file is None and not verbose_mode:
                output_file = "/dev/null"
            measure_bgfa(
                options.get("input_file"),
                output_file=output_file,
                verbose=verbose_mode,
                debug=options.get("debug", False),
            )
            logger.info("Measure command completed successfully")
        except Exception as e:
            logger.error("Error during measurement: %s", e, exc_info=True)
            print(f"Error: {e}", file=sys.stderr)
            sys.exit(1)

    elif options.get("command") == "validate":
        try:
            logger.info("Validating BGFA file: %s", options.get("input_file"))
            verbose_mode = options.get("verbose", False) or options.get("debug", False)
            result = validate_bgfa(
                options.get("input_file"),
                verbose=verbose_mode,
                debug=options.get("debug", False),
            )
            json_str = json.dumps(result, indent=2)
            output_file = options.get("output")
            if output_file:
                logger.info("Writing validation report to file: %s", output_file)
                with open(output_file, "w") as f:
                    f.write(json_str)
            else:
                print(json_str)
            logger.info("Validation command completed successfully")
        except Exception as e:
            logger.error("Error during validation: %s", e, exc_info=True)
            print(f"Error: {e}", file=sys.stderr)
            sys.exit(1)

    elif options.get("command") == "show-full-encodings":
        print(json.dumps(show_full_encodings(), indent=2))

    elif options.get("command") == "dump":
        try:
            logger.info("Dumping BGFA file: %s", options.get("input_file"))
            verbose_mode = options.get("verbose", False) or options.get("debug", False)
            text_format = options.get("text", False)
            
            # Import the dump_bgfa function
            from pygfa.bgfa import dump_bgfa
            
            # Capture the output
            import io
            from contextlib import redirect_stdout
            
            f = io.StringIO()
            with redirect_stdout(f):
                dump_bgfa(options.get("input_file"), text_format=text_format)
            output = f.getvalue()
            
            # Output to file or stdout
            output_file = options.get("output")
            
            if output_file:
                logger.info("Writing dump to file: %s", output_file)
                with open(output_file, "w") as f:
                    f.write(output)
            else:
                print(output)
            
            logger.info("Dump command completed successfully")
        except Exception as e:
            logger.error("Error during dump: %s", e, exc_info=True)
            print(f"Error: {e}", file=sys.stderr)
            sys.exit(1)

    else:
        # No command specified
        logger.error("No command specified. Use 'bgfa', 'cat', 'measure', 'validate', 'dump', or 'show-full-encodings'.")
        print("Error: No command specified. Use 'bgfa', 'cat', 'measure', 'validate', 'dump', or 'show-full-encodings'.", file=sys.stderr)
        sys.exit(1)
